generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserPreference {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  categoryOrder String[] @default([]) @map("category_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

model CustomItem {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  label      String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, categoryId])
  @@map("custom_items")
}

model ChecklistItem {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  categoryId String    @map("category_id")
  itemId     String    @map("item_id")
  checked    Boolean   @default(false)
  dueDate    DateTime? @map("due_date") @db.Date
  memo       String?   @default("") @map("memo")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([userId, itemId])
  @@index([userId])
  @@map("checklist_items")
}

model BudgetItem {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  budget     Int      @default(0)
  spent      Int      @default(0)
  note       String?  @default("")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, categoryId])
  @@index([userId])
  @@map("budget_items")
}

model SharedChecklist {
  id            String   @id @default(cuid())
  ownerId       String   @map("owner_id")
  partnerEmail  String   @map("partner_email")
  partnerUserId String?  @map("partner_user_id")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([ownerId, partnerEmail])
  @@index([partnerEmail])
  @@index([partnerUserId])
  @@map("shared_checklists")
}

model NotificationSetting {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  enabled    Boolean  @default(true)
  daysBefore Int      @default(3) @map("days_before")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}
